# Salin file ini menjadi .env untuk development lokal,
# lalu isi dengan URL backend Flask kamu.
#
# Development lokal (backend jalan di komputer sendiri):
# VITE_API_URL=http://localhost:5000
#
# Production (setelah backend di-deploy ke Railway):
# VITE_API_URL=https://nama-app-kamu.up.railway.app

VITE_API_URL=http://localhost:5000